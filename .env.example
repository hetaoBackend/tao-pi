DEEPSEEK_API_KEY=your_deepseek_api_key
PI_PROVIDER=deepseek
PI_MODEL=deepseek-v4-flash

# Optional base URL override for OpenAI-compatible gateways/proxies.
# PI_BASE_URL=http://localhost:11434/v1

# Optional API key override. Useful for local/proxy endpoints that do not use provider-specific env vars.
# PI_API_KEY=your_api_key

# Optional. Enables the web_search and web_fetch tools through Firecrawl.
# FIRECRAWL_API_KEY=fc-your_firecrawl_api_key
# FIRECRAWL_BASE_URL=https://api.firecrawl.dev

# Optional. Comma-separated non-core plugins. Defaults to todo,memory,skills. Use "none" to disable optional plugin capabilities.
# PI_PLUGINS=todo,memory,skills

# Optional. Defaults to .pi-memory under PI_WORKSPACE_ROOT. Stores persistent memory plugin files.
# PI_MEMORY_DIR=.pi-memory

# Optional. Colon-separated skill roots. Defaults to ~/.tao/skills and ./.tao/skills under PI_WORKSPACE_ROOT.
# Relative paths are resolved from PI_WORKSPACE_ROOT, and "~" expands to the user's home directory.
# Each direct child with SKILL.md is advertised to the agent.
# Later roots override earlier roots when they define the same skill name.
# PI_SKILLS_DIRS=~/.tao/skills:.tao/skills

# Optional template when PI_MODEL is not in pi-ai's registry.
# Template controls API protocol, context limits, compatibility flags, etc.
# PI_MODEL_TEMPLATE=deepseek-v4-flash

# Optional OpenAI-compatible compatibility override.
# Set false for endpoints that reject the "developer" role, e.g. Volcengine Coding Plan.
# PI_SUPPORTS_DEVELOPER_ROLE=false

# Optional. Defaults to the directory where you run the app.
# PI_WORKSPACE_ROOT=/Users/taohe/Documents/learning-pi

# Optional. Defaults to Node's local timezone. Used for the current date appended to the prompt.
# PI_TIMEZONE=Asia/Shanghai

# Optional. Defaults to .pi-sessions.sqlite in the directory where you run the app.
# PI_SESSION_DB=.pi-sessions.sqlite

# Optional. Prepended to the latest user text message before each model call.
# This changes what the model sees, not the messages saved in SQLite.
# PI_CONTEXT_PREFIX=Use concise Chinese and mention when file tools are needed.
